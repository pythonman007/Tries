class Node:
    def __init__(self):
        self.links = [None]*2
    def containsKey(self,bit):
        if(self.links[bit]!=None):
            return True 
        return False 
    def put(self,bit,node):
        self.links[bit] = node 
    def get(self,bit):
        return self.links[bit] 
class Trie:
    def __init__(self):
        self.root = Node()
    def insert(self,num):
        node = self.root 
        for i in range(31,-1,-1):
            bit = (num>>i)&1
            if(node.containsKey(bit) == False):
                node.put(bit,Node())
            node = node.get(bit)
    def getMaxValue(self,num):
            node = self.root 
            Num = 0
            for i in range(31,-1,-1):
                bit = (num>>i)&1 
                if(node.containsKey(1-bit)):
                    Num|=(1<<i)
                    node = node.get(1-bit)
                else:
                    node = node.get(bit)
            return Num
class Solution:
    def findMaximumXOR(self, nums: List[int]) -> int:
        trie = Trie()
        for num in nums:
            trie.insert(num)
        maxNum = 0 
        for num in nums:
            x=trie.getMaxValue(num)
            if(x>maxNum):
                maxNum = x 
        return maxNum
