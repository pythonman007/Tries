class Node:
    def __init__(self):
        self.links = [None]*26 
        self.flag = False 
    def containsKey(self,ch):
        if(self.links[ord(ch)-ord('a')]!=None):
            return True 
        return False 
    def put(self,ch,node):
        self.links[ord(ch)-ord('a')] = node
    def get(self,ch):
        return self.links[ord(ch)-ord('a')] 
class Trie:
    def __init__(self):
        self.root = Node()
    def insert(self,word):
        node = self.root 
        for ch in word:
            if(node.containsKey(ch) == False):
                node.put(ch,Node())
            node = node.get(ch) 
        node.flag = True 
    def checkIfPrefixExisits(self,word):
        node = self.root 
        for ch in word:
            if(node.containsKey(ch) == False):
                return False
            node = node.get(ch) 
            if(node.flag == False):
                return False
        return True 
class Solution:
    def longestValidWord(self, words):
        # code here 
        trie = Trie() 
        for word in words:
            trie.insert(word)
        longest = "" 
        for word in words:
            if(trie.checkIfPrefixExisits(word)):
                if(len(word)>len(longest)):
                    longest = word 
                elif(len(word) == len(longest) and word<longest):
                    longest = word 
        if(len(longest) == 0):
            return "" 
        return longest 
